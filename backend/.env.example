# ======================================================================
# Hridaya Creations Backend - Environment Configuration (sample)
# Copy to `.env` and adjust values. NEVER commit the real .env file.
# ======================================================================

# --- Runtime profile ---
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# --- PostgreSQL ---
DB_URL=jdbc:postgresql://localhost:5432/hridaya_creations
DB_USERNAME=postgres
DB_PASSWORD=postgres
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# --- JWT ---
# Generate a strong Base64 secret (>= 256-bit). Example:
#   openssl rand -base64 64
JWT_SECRET=bXlfc3VwZXJfc2VjdXJlX2p3dF9zZWNyZXRfa2V5X2Zvcl9ocmlkYXlhX2NyZWF0aW9uc18yMDI2X3Byb2R1Y3Rpb25fdXNl
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000
JWT_ISSUER=hridaya-creations

# --- Default Admin (seeded on first boot) ---
ADMIN_EMAIL=admin@ridhayacreations.com
ADMIN_PASSWORD=Admin@12345
ADMIN_FIRST_NAME=Hridaya
ADMIN_LAST_NAME=Admin
ADMIN_MOBILE=9999999999

# --- Cloudinary ---
CLOUDINARY_ENABLED=true
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=hridaya-creations

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Order pricing ---
ORDER_GST_PERCENTAGE=18
ORDER_DELIVERY_CHARGE=50
ORDER_FREE_DELIVERY_THRESHOLD=500

# --- Mail (optional; password reset notifications) ---
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@hridayacreations.com
FRONTEND_RESET_PASSWORD_URL=http://localhost:3000/reset-password

# --- Seeding ---
SEED_SAMPLE_DATA=true

{
  "info": {
    "name": "Hridaya Creations API",
    "description": "Postman collection for the Hridaya Creations personalized gifting backend. Set the `baseUrl` variable, then run Auth > Login (or Register) — the JWT is saved automatically and reused by every other request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "categoryId", "value": "1" },
    { "key": "productId", "value": "1" },
    { "key": "addressId", "value": "1" },
    { "key": "cartItemId", "value": "1" },
    { "key": "orderId", "value": "1" },
    { "key": "userId", "value": "1" },
    { "key": "reviewId", "value": "1" },
    { "key": "imageId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "register"] },
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Aarav\",\n  \"lastName\": \"Sharma\",\n  \"email\": \"aarav.sharma@example.com\",\n  \"mobileNumber\": \"9876543210\",\n  \"password\": \"Secret@123\",\n  \"confirmPassword\": \"Secret@123\"\n}" }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "if (pm.response.code === 201) {",
              "  const d = pm.response.json().data;",
              "  pm.collectionVariables.set('accessToken', d.accessToken);",
              "  pm.collectionVariables.set('refreshToken', d.refreshToken);",
              "}"
            ] } }
          ]
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@ridhayacreations.com\",\n  \"password\": \"Admin@12345\"\n}" }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('login ok', () => pm.response.code === 200);",
              "if (pm.response.code === 200) {",
              "  const d = pm.response.json().data;",
              "  pm.collectionVariables.set('accessToken', d.accessToken);",
              "  pm.collectionVariables.set('refreshToken', d.refreshToken);",
              "}"
            ] } }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "refresh-token"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          },
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "if (pm.response.code === 200) {",
              "  const d = pm.response.json().data;",
              "  pm.collectionVariables.set('accessToken', d.accessToken);",
              "  pm.collectionVariables.set('refreshToken', d.refreshToken);",
              "}"
            ] } }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "logout"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "forgot-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"aarav.sharma@example.com\"\n}" }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "reset-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"PASTE_RESET_TOKEN\",\n  \"newPassword\": \"NewSecret@123\",\n  \"confirmPassword\": \"NewSecret@123\"\n}" }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/change-password", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "change-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"Secret@123\",\n  \"newPassword\": \"NewSecret@123\",\n  \"confirmPassword\": \"NewSecret@123\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        { "name": "Get My Profile", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/users/me", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "me"] } } },
        { "name": "Update My Profile", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/users/me", "host": ["{{baseUrl}}"], "path": ["api", "v1", "users", "me"] }, "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Aarav\",\n  \"lastName\": \"Sharma\",\n  \"mobileNumber\": \"9876543211\"\n}" } } }
      ]
    },
    {
      "name": "Products (public)",
      "item": [
        { "name": "Search Products", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/products?keyword=mug&page=0&size=10&sortBy=createdAt&sortDir=desc", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products"], "query": [ { "key": "keyword", "value": "mug" }, { "key": "categoryId", "value": "", "disabled": true }, { "key": "minPrice", "value": "", "disabled": true }, { "key": "maxPrice", "value": "", "disabled": true }, { "key": "tag", "value": "", "disabled": true }, { "key": "page", "value": "0" }, { "key": "size", "value": "10" }, { "key": "sortBy", "value": "createdAt" }, { "key": "sortDir", "value": "desc" } ] } } },
        { "name": "Featured Products", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/products/featured", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "featured"] } } },
        { "name": "Latest Products", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/products/latest", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "latest"] } } },
        { "name": "Get Product By Id", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "{{productId}}"] } } },
        { "name": "Get Product Reviews", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/products/{{productId}}/reviews", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "{{productId}}", "reviews"] } } }
      ]
    },
    {
      "name": "Categories (public)",
      "item": [
        { "name": "List Categories", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/categories", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categories"] } } },
        { "name": "Get Category By Id", "request": { "auth": { "type": "noauth" }, "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categories", "{{categoryId}}"] } } }
      ]
    },
    {
      "name": "Cart",
      "item": [
        { "name": "Get Cart", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/cart", "host": ["{{baseUrl}}"], "path": ["api", "v1", "cart"] } } },
        { "name": "Add Item", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/cart/items", "host": ["{{baseUrl}}"], "path": ["api", "v1", "cart", "items"] }, "body": { "mode": "raw", "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 2\n}" } } },
        { "name": "Update Item Quantity", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/cart/items/{{cartItemId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "cart", "items", "{{cartItemId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"quantity\": 3\n}" } } },
        { "name": "Increase Item", "request": { "method": "PATCH", "url": { "raw": "{{baseUrl}}/api/v1/cart/items/{{cartItemId}}/increase", "host": ["{{baseUrl}}"], "path": ["api", "v1", "cart", "items", "{{cartItemId}}", "increase"] } } },
        { "name": "Decrease Item", "request": { "method": "PATCH", "url": { "raw": "{{baseUrl}}/api/v1/cart/items/{{cartItemId}}/decrease", "host": ["{{baseUrl}}"], "path": ["api", "v1", "cart", "items", "{{cartItemId}}", "decrease"] } } },
        { "name": "Remove Item", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/v1/cart/items/{{cartItemId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "cart", "items", "{{cartItemId}}"] } } },
        { "name": "Clear Cart", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/v1/cart", "host": ["{{baseUrl}}"], "path": ["api", "v1", "cart"] } } }
      ]
    },
    {
      "name": "Orders",
      "item": [
        { "name": "Place Order", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/orders", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders"] }, "body": { "mode": "raw", "raw": "{\n  \"addressId\": {{addressId}},\n  \"paymentMethod\": \"CASH_ON_DELIVERY\",\n  \"notes\": \"Please deliver after 6 PM\"\n}" } } },
        { "name": "My Orders", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/orders?page=0&size=10", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders"], "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "10" } ] } } },
        { "name": "Get Order", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders", "{{orderId}}"] } } },
        { "name": "Cancel Order", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}/cancel", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders", "{{orderId}}", "cancel"] }, "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Ordered by mistake\"\n}" } } }
      ]
    },
    {
      "name": "Addresses",
      "item": [
        { "name": "List Addresses", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/addresses", "host": ["{{baseUrl}}"], "path": ["api", "v1", "addresses"] } } },
        { "name": "Create Address", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/addresses", "host": ["{{baseUrl}}"], "path": ["api", "v1", "addresses"] }, "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Aarav Sharma\",\n  \"mobileNumber\": \"9876543210\",\n  \"houseNumber\": \"Flat 4B\",\n  \"street\": \"MG Road\",\n  \"city\": \"Bengaluru\",\n  \"state\": \"Karnataka\",\n  \"country\": \"India\",\n  \"pincode\": \"560001\",\n  \"defaultAddress\": true\n}" } } },
        { "name": "Update Address", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/addresses/{{addressId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "addresses", "{{addressId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Aarav Sharma\",\n  \"mobileNumber\": \"9876543210\",\n  \"houseNumber\": \"Flat 5C\",\n  \"street\": \"MG Road\",\n  \"city\": \"Bengaluru\",\n  \"state\": \"Karnataka\",\n  \"country\": \"India\",\n  \"pincode\": \"560001\",\n  \"defaultAddress\": true\n}" } } },
        { "name": "Delete Address", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/v1/addresses/{{addressId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "addresses", "{{addressId}}"] } } }
      ]
    },
    {
      "name": "Wishlist",
      "item": [
        { "name": "Get Wishlist", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/wishlist", "host": ["{{baseUrl}}"], "path": ["api", "v1", "wishlist"] } } },
        { "name": "Add To Wishlist", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/wishlist", "host": ["{{baseUrl}}"], "path": ["api", "v1", "wishlist"] }, "body": { "mode": "raw", "raw": "{\n  \"productId\": {{productId}}\n}" } } },
        { "name": "Remove From Wishlist", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/v1/wishlist/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "wishlist", "products", "{{productId}}"] } } }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        { "name": "Add Review", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/reviews", "host": ["{{baseUrl}}"], "path": ["api", "v1", "reviews"] }, "body": { "mode": "raw", "raw": "{\n  \"productId\": {{productId}},\n  \"rating\": 5,\n  \"reviewText\": \"Beautiful product, exactly as pictured!\"\n}" } } },
        { "name": "Update Review", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/reviews/{{reviewId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "reviews", "{{reviewId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"rating\": 4,\n  \"reviewText\": \"Still great after a few weeks.\"\n}" } } },
        { "name": "Delete Review", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/v1/reviews/{{reviewId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "reviews", "{{reviewId}}"] } } }
      ]
    },
    {
      "name": "Admin - Categories",
      "item": [
        { "name": "Create Category", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/admin/categories", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "categories"] }, "body": { "mode": "raw", "raw": "{\n  \"categoryName\": \"Personalized Mugs\",\n  \"description\": \"Custom printed mugs\",\n  \"status\": \"ACTIVE\"\n}" } } },
        { "name": "Update Category", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/admin/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "categories", "{{categoryId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"categoryName\": \"Personalized Mugs\",\n  \"description\": \"Updated description\",\n  \"status\": \"ACTIVE\"\n}" } } },
        { "name": "Delete Category", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/v1/admin/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "categories", "{{categoryId}}"] } } },
        { "name": "List Categories (all)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/admin/categories", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "categories"] } } }
      ]
    },
    {
      "name": "Admin - Products",
      "item": [
        { "name": "Create Product", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/admin/products", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "products"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Personalized Magic Mug\",\n  \"description\": \"Heat-reveal photo mug\",\n  \"shortDescription\": \"Magic mug\",\n  \"categoryId\": {{categoryId}},\n  \"sellingPrice\": 349.00,\n  \"originalPrice\": 499.00,\n  \"stockQuantity\": 100,\n  \"featured\": true,\n  \"customizable\": true,\n  \"tags\": [\"mug\", \"magic\", \"photo\"]\n}" } } },
        { "name": "Update Product", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/admin/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "products", "{{productId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Personalized Magic Mug\",\n  \"description\": \"Updated description\",\n  \"categoryId\": {{categoryId}},\n  \"sellingPrice\": 329.00,\n  \"originalPrice\": 499.00,\n  \"stockQuantity\": 120\n}" } } },
        { "name": "Delete Product", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/v1/admin/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "products", "{{productId}}"] } } },
        { "name": "Enable Product", "request": { "method": "PATCH", "url": { "raw": "{{baseUrl}}/api/v1/admin/products/{{productId}}/enable", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "products", "{{productId}}", "enable"] } } },
        { "name": "Disable Product", "request": { "method": "PATCH", "url": { "raw": "{{baseUrl}}/api/v1/admin/products/{{productId}}/disable", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "products", "{{productId}}", "disable"] } } },
        { "name": "Update Pricing", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/admin/products/{{productId}}/pricing", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "products", "{{productId}}", "pricing"] }, "body": { "mode": "raw", "raw": "{\n  \"sellingPrice\": 299.00,\n  \"originalPrice\": 499.00\n}" } } },
        { "name": "Update Stock", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/admin/products/{{productId}}/stock", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "products", "{{productId}}", "stock"] }, "body": { "mode": "raw", "raw": "{\n  \"stockQuantity\": 250\n}" } } },
        { "name": "List Products (all)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/admin/products?page=0&size=10", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "products"], "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "10" }, { "key": "status", "value": "", "disabled": true } ] } } }
      ]
    },
    {
      "name": "Admin - Product Images",
      "item": [
        { "name": "List Images", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/admin/products/{{productId}}/images", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "products", "{{productId}}", "images"] } } },
        { "name": "Upload Image", "request": { "method": "POST", "url": { "raw": "{{baseUrl}}/api/v1/admin/products/{{productId}}/images?primary=true", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "products", "{{productId}}", "images"], "query": [ { "key": "primary", "value": "true" } ] }, "body": { "mode": "formdata", "formdata": [ { "key": "file", "type": "file", "src": [] } ] } } },
        { "name": "Replace Image", "request": { "method": "PUT", "url": { "raw": "{{baseUrl}}/api/v1/admin/products/{{productId}}/images/{{imageId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "products", "{{productId}}", "images", "{{imageId}}"] }, "body": { "mode": "formdata", "formdata": [ { "key": "file", "type": "file", "src": [] } ] } } },
        { "name": "Delete Image", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/api/v1/admin/products/{{productId}}/images/{{imageId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "products", "{{productId}}", "images", "{{imageId}}"] } } }
      ]
    },
    {
      "name": "Admin - Orders",
      "item": [
        { "name": "List Orders", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/admin/orders?page=0&size=10", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "orders"], "query": [ { "key": "status", "value": "", "disabled": true }, { "key": "page", "value": "0" }, { "key": "size", "value": "10" } ] } } },
        { "name": "Get Order", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/admin/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "orders", "{{orderId}}"] } } },
        { "name": "Update Order Status", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": { "raw": "{{baseUrl}}/api/v1/admin/orders/{{orderId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "orders", "{{orderId}}", "status"] }, "body": { "mode": "raw", "raw": "{\n  \"status\": \"CONFIRMED\"\n}" } } }
      ]
    },
    {
